      "Owner": {"DisplayName": "acme", "ID": "abc123"},
      "Grants": [
        {
          "Grantee": {"Type": "Group", "URI": "http://acs.amazonaws.com/groups/global/AllUsers"},
          "Permission": "READ"
        }
      ]
    },
    "listing": {
      "public": true,
      "objects": [
        {"key": "db-backup.sql", "size": 84211234},
