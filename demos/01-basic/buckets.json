        {
          "Grantee": {"Type": "Group", "URI": "http://acs.amazonaws.com/groups/global/AllUsers"},
          "Permission": "READ"
        }
      ]
    },
    "policy": {
      "Version": "2012-10-17",
      "Statement": [
        {
          "Sid": "PublicReadGetObject",
          "Effect": "Allow",
          "Principal": "*",
          "Action": "s3:GetObject",
          "Resource": "arn:aws:s3:::acme-public-assets/*"
        },
        {
          "Sid": "AnyoneCanUpload",
          "Effect": "Allow",
          "Principal": "*",
          "Action": ["s3:PutObject"],
          "Resource": "arn:aws:s3:::acme-public-assets/*"
        }
      ]
    }
  },
  {
